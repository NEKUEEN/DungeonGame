// ─────────────────────────────────────────────────────────────────
//  (1)  วางต่อจากฟังก์ชัน computeBody() ในไฟล์เดิม
// ─────────────────────────────────────────────────────────────────

int Game::computeMentality() const
{
    if (!m_player) return 0;
    const Stats& s = m_player->getStats();

    // sub-stats ปัจจุบัน — เพิ่ม field ใหม่ตรงนี้อย่างเดียว
    int mana      = s.maxMana;
    int magicDmg  = s.maxMagicDmg;
    int magicRes  = s.maxMagicRes;
    // อนาคต: int poisonRes = s.maxPoisonRes;

    // สูตรเหมือน body — ปรับ weight ทีหลังได้
    return (int)(mana * 0.4f + magicDmg * 0.3f + magicRes * 0.3f);
    // อนาคต: + poisonRes*0.1f ฯลฯ
}

