// ════════════════════════════════════════════════════════════════
//  [A]  pickRandomMonster()  —  NEW FUNCTION
//       วางต่อจาก spawnEnemy() หรือที่ไหนก็ได้ใน Game.cpp
//
//  Spawn weight ตาม floor:
//    Normal : 60%  (ทุก floor)
//    Rare   : 25%  (ทุก floor)
//    Elite  : 12%  (floor 1+)
//    Boss   :  0%  (เกิดจาก kill trigger เท่านั้น — ไม่ใส่ใน random pool)
//
//  ยิ่ง floor สูง Elite % เพิ่มขึ้น Normal ลด
// ════════════════════════════════════════════════════════════════

std::string Game::pickRandomMonster(int floor)
{
    // น้ำหนักปรับตาม floor (Boss = 0 เสมอ ไม่ spawn แบบ random)
    float wNormal = std::max(30.f, 60.f - (floor - 1) * 3.f);  // ลดลงตาม floor
    float wRare   = 25.f;
    float wElite  = std::min(40.f, 12.f + (floor - 1) * 2.f);  // เพิ่มขึ้นตาม floor
    float total   = wNormal + wRare + wElite;

    float roll = m_fDist(m_rng) * total;

    std::string rankStr;
    if      (roll < wNormal)          rankStr = "Normal";
    else if (roll < wNormal + wRare)  rankStr = "Rare";
    else                              rankStr = "Elite";

    auto ids = MonsterDB::instance().getByRank(rankStr);

    // fallback: ถ้า rank ว่าง (เช่น JSON ยังไม่มีมอน Rare) ใช้ Normal
    if (ids.empty()) ids = MonsterDB::instance().getByRank("Normal");
    if (ids.empty()) return "";

    std::uniform_int_distribution<int> pick(0, (int)ids.size() - 1);
    return ids[pick(m_rng)];
}


// ════════════════════════════════════════════════════════════════
//  [B]  spawnEnemy()  —  แทนที่ฟังก์ชันเดิม
//       ใช้ pickRandomMonster() แทน rand()%100
// ════════════════════════════════════════════════════════════════

void Game::spawnEnemy(int floor)
{
    std::uniform_int_distribution<int> colDist(1, MAP_COLS - 2);
    std::uniform_int_distribution<int> rowDist(1, MAP_ROWS - 2);

    for (int att = 0; att < 100; ++att)
    {
        int col = colDist(m_rng);
        int row = rowDist(m_rng);
        if (!m_tileMap.isWalkable(col, row)) continue;

        // อย่า spawn ใกล้ player เกินไป
        if (m_player)
        {
            int dx = col - m_player->getCol();
            int dy = row - m_player->getRow();
            if (dx*dx + dy*dy < 36) continue;
        }

        std::string id = pickRandomMonster(floor);
        if (id.empty()) return;

        m_enemies.push_back(new Enemy(id, col, row, TILE_SIZE, floor));
        return;
    }
}


// ════════════════════════════════════════════════════════════════
//  [C]  spawnBoss()  —  NEW FUNCTION
//       วางต่อจาก spawnEnemy()
// ════════════════════════════════════════════════════════════════

void Game::spawnBoss(const std::string& family)
{
    // หา boss id ของ family นี้
    auto bossIds = MonsterDB::instance().getByRank("Boss");
    std::string bossId;
    for (const auto& bid : bossIds)
    {
        const MonsterData* d = MonsterDB::instance().get(bid);
        if (d && d->family == family)
        { bossId = bid; break; }
    }

    if (bossId.empty())
    {
        addLog("> [" + family + "] Boss not found in JSON!", sf::Color(200,100,50));
        return;
    }

    // หา tile ว่างที่ไม่ใกล้ player
    std::uniform_int_distribution<int> colDist(1, MAP_COLS - 2);
    std::uniform_int_distribution<int> rowDist(1, MAP_ROWS - 2);

    for (int att = 0; att < 300; ++att)
    {
        int col = colDist(m_rng);
        int row = rowDist(m_rng);
        if (!m_tileMap.isWalkable(col, row)) continue;

        // spawn ไกลจาก player อย่างน้อย 8 tile
        if (m_player)
        {
            int dx = col - m_player->getCol();
            int dy = row - m_player->getRow();
            if (dx*dx + dy*dy < 64) continue;
        }

        m_enemies.push_back(new Enemy(bossId, col, row, TILE_SIZE, m_dungeonFloor));
        m_bossActive[family] = true;

        addLog("> *** " + family + " BOSS APPEARS! ***", sf::Color(255, 100, 50));
        addLog("> [" + family + "] slaughter has summoned a guardian!", sf::Color(255, 160, 50));
        return;
    }
}


// ════════════════════════════════════════════════════════════════
//  [D]  onEnemyKilled()  —  NEW FUNCTION
//       เรียกในทุกจุดที่ enemy ตาย แทนบล็อก "enemy dead" เดิม
//
//  วิธีใช้ร่วมกับโค้ดเดิม:
//  หลัง addLog("> "+enemy->getName()+" dead! ...") ทุกจุด
//  ให้เพิ่ม:  onEnemyKilled(enemy);
// ════════════════════════════════════════════════════════════════

void Game::onEnemyKilled(Enemy* enemy)
{
    if (!enemy) return;

    // Boss ที่ตายให้ reset flag ของ family นั้น
    if (enemy->getRank() == EnemyRank::Boss)
    {
        m_bossActive[enemy->getFamily()] = false;
        addLog("> Boss defeated! The " + enemy->getFamily() +
               " threat is quelled... for now.", sf::Color(255, 200, 80));
        return;
    }

    // Non-boss: นับ kill count ของ family
    const std::string& fam = enemy->getFamily();
    m_familyKillCount[fam]++;

    int count = m_familyKillCount[fam];

    // แจ้ง milestone ทุก 10 ตัว
    if (count % 10 == 0 && count < BOSS_KILL_THRESHOLD)
    {
        int remaining = BOSS_KILL_THRESHOLD - count;
        addLog("> " + fam + " kills: " + std::to_string(count) +
               " / " + std::to_string(BOSS_KILL_THRESHOLD) +
               " (" + std::to_string(remaining) + " more to summon boss)",
               sf::Color(200, 160, 60));
    }

    // Boss trigger
    if (count >= BOSS_KILL_THRESHOLD && !m_bossActive[fam])
    {
        spawnBoss(fam);
    }
}


